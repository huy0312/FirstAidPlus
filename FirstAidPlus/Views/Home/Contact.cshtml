@{
    ViewData["Title"] = "Liên hệ";
}

<div class="bg-light py-5">
    <div class="container text-center">
        <h1 class="fw-bold display-5 mb-3">Liên hệ với chúng tôi</h1>
        <p class="lead text-muted">Có câu hỏi? Chúng tôi luôn sẵn sàng hỗ trợ bạn</p>
    </div>
</div>

<div class="container my-5">
    <div class="row g-5">
        <!-- Contact Info -->
        <div class="col-lg-4">
            <h5 class="fw-bold mb-4">Thông tin liên hệ</h5>
            
            <div class="d-flex mb-4">
                <div class="flex-shrink-0">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="fas fa-phone-alt fs-5"></i>
                    </div>
                </div>
                <div class="ms-3">
                    <h6 class="fw-bold mb-1">Điện thoại</h6>
                    <p class="text-muted small mb-0">Hotline: 1900 1818</p>
                    <p class="text-muted small">Hỗ trợ: 024 1234 5678</p>
                </div>
            </div>

            <div class="d-flex mb-4">
                <div class="flex-shrink-0">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="fas fa-envelope fs-5"></i>
                    </div>
                </div>
                <div class="ms-3">
                    <h6 class="fw-bold mb-1">Email</h6>
                    <p class="text-muted small mb-0">info@firstaid.vn</p>
                    <p class="text-muted small">support@firstaid.vn</p>
                </div>
            </div>

             <div class="d-flex mb-4">
                <div class="flex-shrink-0">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="fas fa-map-marker-alt fs-5"></i>
                    </div>
                </div>
                <div class="ms-3">
                    <h6 class="fw-bold mb-1">Địa chỉ</h6>
                    <p class="text-muted small">123 Đường Lê Lợi, Phường Bến Nghé<br>Quận 1, TP. Hồ Chí Minh</p>
                </div>
            </div>

            <div class="d-flex mb-4">
                <div class="flex-shrink-0">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                        <i class="far fa-clock fs-5"></i>
                    </div>
                </div>
                <div class="ms-3">
                    <h6 class="fw-bold mb-1">Giờ làm việc</h6>
                    <p class="text-muted small mb-0">Thứ 2 - Thứ 6: 8:00 - 18:00</p>
                    <p class="text-muted small">Thứ 7 - CN: 9:00 - 17:00</p>
                </div>
            </div>
            
             <div class="card bg-danger bg-opacity-10 border-danger border-opacity-25 mt-5">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-danger mb-3">Hỗ trợ khẩn cấp</h6>
                    <p class="small text-muted mb-4">Nếu bạn cần hỗ trợ khẩn cấp về kỹ thuật hoặc chứng chỉ, vui lòng gọi hotline của chúng tôi.</p>
                    <a href="tel:19001818" class="btn btn-danger w-100 fw-bold"><i class="fas fa-phone-alt me-2"></i>Gọi ngay: 1900 1818</a>
                </div>
            </div>

        </div>

        <!-- Contact Form -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-4">Gửi tin nhắn cho chúng tôi</h5>
                    
                    @if(TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }

                    <form asp-action="Contact" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Họ và tên *</label>
                                <input type="text" class="form-control" name="name" placeholder="Nguyễn Văn A" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Email *</label>
                                <input type="email" class="form-control" name="email" placeholder="email@example.com" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Số điện thoại</label>
                                <input type="tel" class="form-control" name="phone" placeholder="0901234567">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Chủ đề *</label>
                                <select class="form-select" name="subject" required>
                                    <option value="" selected disabled>Chọn chủ đề</option>
                                    <option value="Tuvan">Tư vấn khóa học</option>
                                    <option value="Hotro">Hỗ trợ kỹ thuật</option>
                                    <option value="Khac">Khác</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Tin nhắn *</label>
                                <textarea class="form-control" name="message" rows="5" placeholder="Nội dung tin nhắn của bạn..." required></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="agree" required>
                                    <label class="form-check-label small text-muted" for="agree">
                                        Tôi đồng ý cho Firstaid+ liên hệ qua email hoặc điện thoại để hỗ trợ yêu cầu của tôi.
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-danger w-100 fw-bold py-3">Gửi tin nhắn</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Map (Placeholder) -->
     <div class="my-5 bg-light d-flex align-items-center justify-content-center text-muted rounded" style="height: 400px;">
        Google Maps Integration Here
    </div>

    <!-- FAQ Section (Simplified) -->
    <div class="text-center mb-5">
        <h3 class="fw-bold mb-2">Câu hỏi thường gặp</h3>
        <a href="#" class="text-danger text-decoration-none">Hoặc xem trang FAQ đầy đủ</a>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 border-light shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Làm sao để đăng ký khóa học?</h6>
                    <p class="small text-muted mb-0">Bạn có thể đăng ký trực tiếp trên website hoặc liên hệ hotline 1900 1818.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 border-light shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Chứng chỉ có giá trị bao lâu?</h6>
                    <p class="small text-muted mb-0">Chứng chỉ có giá trị 2 năm từ ngày cấp.</p>
                </div>
            </div>
        </div>
         <div class="col-md-6">
            <div class="card h-100 border-light shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Có hỗ trợ thanh toán trả góp không?</h6>
                    <p class="small text-muted mb-0">Có, chúng tôi hỗ trợ thanh toán qua thẻ tín dụng với lãi suất 0%.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 border-light shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Tôi có thể học lại miễn phí không?</h6>
                    <p class="small text-muted mb-0">Có, bạn có thể xem lại video bất cứ lúc nào trong thời gian khóa học còn hiệu lực.</p>
                </div>
            </div>
        </div>
    </div>
</div>
