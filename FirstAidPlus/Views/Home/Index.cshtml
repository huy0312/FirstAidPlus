<!-- Condition to show courses -->
@{
    bool hasActiveSubscriptionHome = false;
    if (User.Identity.IsAuthenticated)
    {
        var dbContextHome = Context.RequestServices.GetService<FirstAidPlus.Data.AppDbContext>();
        if (dbContextHome != null)
        {
            var userIdClaim = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdClaim, out int uid))
            {
                hasActiveSubscriptionHome = dbContextHome.UserSubscriptions
                    .Any(s => s.UserId == uid && s.Status == "Active" && (s.EndDate == null || s.EndDate > DateTime.Now));
            }
        }
    }
}

@if (hasActiveSubscriptionHome)
{
<!-- Courses Section -->
<section id="courses" class="py-5 bg-light">
    <div class="container py-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5">
            <div>
                <span class="section-badge">Chương trình học</span>
                <h2 class="display-5 section-title mb-0">Khóa Học Nổi Bật</h2>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-controller="Course" asp-action="Index" class="btn btn-outline-brand rounded-pill px-4 fw-bold">
                    Xem tất cả khóa học <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
        
        <div class="row g-4">
            @foreach (var course in Model.FeaturedCourses)
            {
                <div class="col-md-4">
                    <div class=" आधुनिक-card h-100 border-0 shadow-sm card-hover overflow-hidden" style="background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); transition: transform 0.3s ease;">
                        <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="text-decoration-none text-dark">
