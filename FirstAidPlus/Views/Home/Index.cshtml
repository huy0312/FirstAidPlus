@model FirstAidPlus.ViewModels.LandingPageViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* Clean, Modern Brand Colors */
    :root {
        --brand-red: #d71920;
        --brand-red-light: #ff4d4d;
        --brand-red-dark: #b5131a;
        --bg-light: #f8fafc;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
    }

    body {
        background-color: var(--bg-light);
        color: var(--text-primary);
        font-family: 'Inter', sans-serif;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #ffffff 0%, #fffafa 100%);
        position: relative;
        overflow: hidden;
        padding-top: 80px;
        padding-bottom: 100px;
    }
    
    .hero-gradient-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.15;
    }
    .orb-1 { width: 500px; height: 500px; background: var(--brand-red); top: -100px; right: -100px; }
    .orb-2 { width: 400px; height: 400px; background: #ff7b7b; bottom: -50px; left: -100px; }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-title {
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1.15;
        color: var(--text-primary);
    }
    
    .text-brand {
        color: var(--brand-red);
    }

    /* Buttons */
    .btn-brand {
        background-color: var(--brand-red);
        color: white;
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(215, 25, 32, 0.2);
    }
    .btn-brand:hover {
        background-color: var(--brand-red-dark);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(215, 25, 32, 0.3);
    }
    
    .btn-outline-brand {
        border: 2px solid var(--brand-red);
        color: var(--brand-red);
        transition: all 0.3s ease;
    }
    .btn-outline-brand:hover {
        background-color: var(--brand-red);
        color: white;
    }

    /* Cards - Glassmorphism & Soft Shadows */
    .modern-card {
        background: white;
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
        height: 100%;
    }
    .modern-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    /* Features Section */
    .feature-icon-wrapper {
        width: 70px;
        height: 70px;
        background: rgba(215, 25, 32, 0.08);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--brand-red);
        font-size: 1.8rem;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }
    .modern-card:hover .feature-icon-wrapper {
        background: var(--brand-red);
        color: white;
        transform: rotate(5deg) scale(1.1);
    }

    /* Floating Animations */
    .floating-img {
        animation: float 6s ease-in-out infinite;
    }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }
    
    /* Stats tags in Hero */
    .glass-stat {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        border-radius: 16px;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* Section Headers */
    .section-badge {
        background: rgba(215, 25, 32, 0.1);
        color: var(--brand-red);
        padding: 8px 16px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 15px;
    }
    .section-title {
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 20px;
    }

    /* Custom Wave */
    .wave-bottom {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        overflow: hidden;
        line-height: 0;
    }
    .wave-bottom svg {
        position: relative;
        display: block;
        width: calc(100% + 1.3px);
        height: 80px;
    }
    .wave-bottom .shape-fill {
        fill: #FFFFFF;
    }
</style>

