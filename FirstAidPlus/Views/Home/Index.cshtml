                                @if(course.IsPopular)
                                {
                                    <span class="position-absolute top-0 end-0 bg-danger text-white px-3 py-1 m-3 rounded-pill fw-bold" style="font-size: 0.8rem; box-shadow: 0 4px 10px rgba(215,25,32,0.3);">
                                        <i class="fas fa-fire me-1"></i> Hot
                                    </span>
                                }
                            </div>
                            <div class="card-body p-4">
                                <span class="badge bg-light text-danger mb-3 px-2 py-1 border border-danger fw-bold border-opacity-25">@course.GetFormattedDuration()</span>
                                <h4 class="fw-bold mb-2 text-dark">@course.Title</h4>
                                <p class="text-secondary small mb-4 line-clamp-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@course.Description</p>
                                
                                <div class="border-top pt-3 mt-auto">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="text-dark small fw-bold">
                                            <i class="fas fa-award text-warning me-1"></i> @course.CertificateName
                                        </div>
                                        <div class="text-danger fw-bold"><i class="fas fa-chevron-right"></i></div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
}

