<!-- App Download -->
<section class="py-5 bg-white">
    <div class="container py-5">
        <div class="row align-items-center p-4 p-md-5 rounded-4" style="background: rgba(215, 25, 32, 0.03); border: 1px solid rgba(215, 25, 32, 0.1);">
            <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
                <span class="section-badge">Học mọi lúc mọi nơi</span>
