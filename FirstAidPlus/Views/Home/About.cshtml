        <div class="container">
            <div class="glass-container p-4 p-md-5 rounded-4 shadow-sm border-white-10">
                <div class="row g-4 text-center">
                    <div class="col-6 col-md-3">
                        <h2 class="fw-bold text-primary mb-1 counter" data-target="50000">50K+</h2>
                        <p class="text-muted mb-0">Học viên</p>
                    </div>
                    <div class="col-6 col-md-3">
                        <h2 class="fw-bold text-primary mb-1 counter" data-target="100">100+</h2>
                        <p class="text-muted mb-0">Doanh nghiệp</p>
                    </div>
                    <div class="col-6 col-md-3">
                        <h2 class="fw-bold text-primary mb-1 counter" data-target="20">20+</h2>
                        <p class="text-muted mb-0">Chuyên gia</p>
                    </div>
                    <div class="col-6 col-md-3">
