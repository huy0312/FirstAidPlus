                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-circle bg-success text-white">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Chuẩn Quốc Tế</h6>
                                    <small class="text-muted">AHA & Red Cross</small>
                                </div>
                            </div>
                        </div>
                        <div class="glass-card floating-card-2 p-3 d-none d-md-block">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-circle bg-danger text-white">
                                    <i class="bi bi-heart-pulse-fill"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">50,000+</h6>
                                    <small class="text-muted">Học viên đã tham gia</small>
                                </div>
                            </div>
                        </div>
                        <img src="/images/about/hero.png" alt="First Aid Training" class="img-fluid rounded-4-custom shadow-2xl main-hero-img">
                    </div>
                </div>
            </div>
        </div>
        <div class="shape-blob shape-1"></div>
        <div class="shape-blob shape-2"></div>
    </section>

    <!-- Stats Section -->
