<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expert Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="icon" type="image/png" href="~/favicon.png?v=1">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; overflow-x: hidden; }
        .sidebar {
            width: 260px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background: white;
            z-index: 1000;
            border-right: 1px solid #eee;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
        }
        .sidebar.collapsed { width: 80px; }
        .sidebar.collapsed .sidebar-brand span,
        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .mt-auto .nav-text { display: none; }
        
        .sidebar.collapsed .sidebar-brand { justify-content: center; }
        .sidebar.collapsed .nav-link { justify-content: center; padding: 12px; }
        .sidebar.collapsed .nav-link i { margin-right: 0; font-size: 1.2rem; }

        .main-content {
            margin-left: 260px;
            padding: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .main-content.collapsed { margin-left: 80px; }

        .sidebar-header {
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 80px;
        }
        
        .toggle-sidebar {
            background: #f8f9fa;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            color: #4e73df;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .toggle-sidebar:hover { background: #eef2ff; color: #224abe; }
        
        .nav-link {
            color: #6c757d;
            font-weight: 500;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            transition: all 0.2s;
        }
        .nav-link:hover, .nav-link.active {
            color: #4e73df;
            background-color: #f0f4ff;
        }
        .nav-link i { width: 24px; margin-right: 12px; }
        .sidebar.collapsed .nav-link i { margin-right: 0; }

        .header {
            background: white;
            padding: 15px 30px;
            border-radius: 12px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-0 border-end" id="expertSidebar">
        <div class="sidebar-header">
            <a class="navbar-brand sidebar-brand p-0 m-0 fw-bold fs-4 text-primary d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/favicon.png" alt="Logo" height="32" class="me-2" />
                <span class="ms-1">FirstAid<span class="text-danger">+</span></span>
            </a>
            <button class="toggle-sidebar" id="toggleSidebar">
                <i class="fas fa-bars"></i>
            </button>
        </div>
        
        <ul class="nav flex-column flex-grow-1 px-3">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-action="Dashboard" title="Tổng quan">
                    <i class="fas fa-th-large"></i>
                    <span class="nav-text">Tổng quan</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyCourses" ? "active" : "")" asp-action="MyCourses" title="Quản lý khóa học">
                     <i class="fas fa-book-open"></i>
                     <span class="nav-text">Quản lý khóa học</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Enrollments" ? "active" : "")" asp-action="Enrollments" title="Học viên">
                    <i class="fas fa-user-graduate"></i>
                    <span class="nav-text">Học viên</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageGame" || ViewContext.RouteData.Values["Action"]?.ToString() == "EditCategory" ? "active" : "")" asp-action="ManageGame" title="Trò chơi">
                    <i class="fas fa-gamepad"></i>
                    <span class="nav-text">Trò chơi</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Chat" ? "active" : "")" asp-action="Chat" title="Tin nhắn">
                    <i class="fas fa-comments"></i>
                    <span class="nav-text">Tin nhắn</span>
                </a>
            </li>
             <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Qualifications" ? "active" : "")" asp-action="Qualifications" title="Chứng chỉ hành nghề">
                    <i class="fas fa-certificate"></i>
                    <span class="nav-text">Chứng chỉ hành nghề</span>
                </a>
            </li>
            <li class="nav-item">
                 <a class="nav-link" href="#" title="Báo cáo">
                    <i class="fas fa-chart-bar"></i>
                    <span class="nav-text">Báo cáo</span>
                </a>
            </li>
        </ul>

        <div class="mt-auto border-top p-3 px-3">
             <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout" title="Đăng xuất">
                <i class="fas fa-sign-out-alt"></i>
                <span class="nav-text">Đăng xuất</span>
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- Header -->
        <div class="header">
            <h4 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h4>
            <div class="d-flex align-items-center gap-3">
                 <div class="dropdown position-relative">
                    <a href="#" class="text-muted text-decoration-none position-relative" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
                        <i class="far fa-bell fa-lg"></i>
                        <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.6rem; padding: 0.2rem 0.35rem;">0</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 p-0" aria-labelledby="notificationDropdown" style="width: 340px; max-height: 450px; overflow-y: auto;">
                        <li class="dropdown-header border-bottom p-3 d-flex justify-content-between align-items-center bg-light rounded-top">
                            <h6 class="mb-0 fw-bold text-dark">Thông báo</h6>
                            <a href="javascript:void(0)" class="text-decoration-none small text-primary" id="markAllRead">Đánh dấu đã đọc</a>
                        </li>
                        <div id="notificationList">
                            <li class="p-5 text-center text-muted small"><i class="far fa-bell-slash mb-2 fs-4 opacity-50"></i><br/>Không có thông báo mới</li>
                        </div>
                        <li class="border-top text-center p-2 bg-light rounded-bottom">
                            <a href="#" class="text-decoration-none small fw-bold text-primary">Xem tất cả thông báo</a>
                        </li>
                    </ul>
                </div>
                <div class="border-start mx-2" style="height: 20px;"></div>
                <div class="d-flex align-items-center gap-2">
                     <img src="@(User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value ?? "https://ui-avatars.com/api/?name=" + User.Identity.Name)" 
                          class="rounded-circle" width="40" height="40" alt="Avatar">
                    <div>
                        <div class="fw-bold small">@User.Identity.Name</div>
                         <div class="text-muted small" style="font-size: 0.75rem;">Expert Instructor</div>
                    </div>
                </div>
            </div>
        </div>

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('expertSidebar');
            const mainContent = document.getElementById('mainContent');
            const toggleBtn = document.getElementById('toggleSidebar');
            
            // Check for saved state
            if (localStorage.getItem('expertSidebarCollapsed') === 'true') {
                sidebar.classList.add('collapsed');
                mainContent.classList.add('collapsed');
            }
            
            toggleBtn.addEventListener('click', function() {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('collapsed');
                localStorage.setItem('expertSidebarCollapsed', sidebar.classList.contains('collapsed'));
            });
        });
    </script>
</body>
</html>
