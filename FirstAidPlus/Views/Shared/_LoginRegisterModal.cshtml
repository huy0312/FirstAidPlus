<script>
    function toggleExpertHorizontal(e) {
        const dialog = document.getElementById('authModalDialog');
        const leftBanner = document.getElementById('leftBannerCol');
        const rightForm = document.getElementById('rightFormCol');
        const standardCol = document.getElementById('standardFieldsCol');
        const expertCol = document.getElementById('expertFieldsCol');
        const card = document.getElementById('expertToggleCard');
        const header = document.getElementById('registerHeader');

        if (e.target.checked) {
            card.classList.add('active');
            
            // Expand modal
            dialog.classList.remove('modal-lg');
            dialog.classList.add('modal-xl');
            
            // Adjust main grid. Banner stays col-md-4
            leftBanner.className = "col-lg-4 d-none d-lg-block transition-custom";
            rightForm.className = "col-lg-8 transition-custom";

            // Adjust form grid. Divide into 2 columns.
            standardCol.className = "col-lg-6 transition-custom";
            expertCol.style.display = "block";
            header.style.display = "none";
            
            setTimeout(() => {
                expertCol.classList.add('show-horizontal');
            }, 50);
        } else {
            card.classList.remove('active');
            
            // Revert modal
            dialog.classList.add('modal-lg');
            dialog.classList.remove('modal-xl');

            // Revert main grid
            leftBanner.className = "col-md-5 d-none d-md-block transition-custom";
            rightForm.className = "col-md-7 transition-custom";

            // Revert form grid
            standardCol.className = "col-12 transition-custom";
            expertCol.classList.remove('show-horizontal');
            header.style.display = "block";
            
            setTimeout(() => {
                if(!document.getElementById('expertToggle').checked) {
                    expertCol.style.display = "none";
                }
            }, 400);
        }
    }

    // Ensures reset logic triggers when switching tabs 
    function resetRegisterLayout() {
        const toggle = document.getElementById('expertToggle');
        if (toggle && toggle.checked) {
             toggle.checked = false;
             toggleExpertHorizontal({ target: toggle });
        }
    }
    
    function applyRegisterLayout() {
         const toggle = document.getElementById('expertToggle');
         if (toggle && toggle.checked) {
              toggleExpertHorizontal({ target: toggle });
         }
    }

    function updateFileName(input) {
        const box = document.getElementById('uploadBox');
        const text = document.getElementById('fileNameText');
        if (input.files && input.files[0]) {
            box.classList.add('has-file');
            text.innerHTML = '<span class="text-danger fw-bold"><i class="fas fa-file-image me-1"></i> ' + input.files[0].name + '</span>';
        } else {
            box.classList.remove('has-file');
            text.innerHTML = 'Ảnh JPG, PNG.';
        }
    }

    async function handleLogin(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);
        const errorDiv = document.getElementById('login-error');
        const btn = document.getElementById('loginBtn');
        
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
        
        try {
            const response = await fetch('@Url.Action("Login", "Account")', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                if (result.redirectUrl) window.location.href = result.redirectUrl;
                else window.location.reload();
            } else {
                errorDiv.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i> ' + (result.message || "Đăng nhập thất bại");
                errorDiv.classList.remove('d-none');
                btn.disabled = false;
                btn.innerHTML = 'Đăng nhập';
            }
        } catch (error) {
            errorDiv.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i> Đã có lỗi xảy ra.';
            errorDiv.classList.remove('d-none');
            btn.disabled = false;
            btn.innerHTML = 'Đăng nhập';
        }
    }

    async function handleRegister(event) {
        event.preventDefault();
        const form = event.target;
        const errorDiv = document.getElementById('register-error');
        const submitBtn = document.getElementById('registerBtn');
        
        document.getElementById('reg-username').value = document.getElementById('reg-email').value;
        document.getElementById('reg-confirm-password').value = document.getElementById('reg-password').value;
        
        const formData = new FormData(form);
        
        errorDiv.classList.add('d-none');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
        
        try {
            const response = await fetch('@Url.Action("Register", "Account")', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            if (result.success) {
                submitBtn.innerHTML = '<i class="fas fa-check text-white me-2"></i>Thành công!';
                setTimeout(() => window.location.href = result.redirectUrl, 1000);
            } else {
                errorDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> ' + (result.message || "Đăng ký thất bại");
                errorDiv.classList.remove('d-none');
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Đăng ký tài khoản';
            }
        } catch (error) {
            errorDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Có lỗi xảy ra. Kiểm tra kết nối.';
            errorDiv.classList.remove('d-none');
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Đăng ký tài khoản';
        }
    }
</script>
