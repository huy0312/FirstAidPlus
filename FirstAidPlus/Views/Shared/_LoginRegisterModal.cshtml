<style>
    .auth-modal-content {
        border-radius: 1.5rem;
        overflow: hidden;
        border: none;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    
    .modal-close-custom {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        background-color: white;
        opacity: 0.8;
        border-radius: 50%;
        padding: 0.6rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }
    .modal-close-custom:hover {
        opacity: 1;
        transform: rotate(90deg) scale(1.1);
        background-color: #f8f9fa;
    }

    .nav-auth {
        background: #f1f5f9;
        border-radius: 1rem;
        padding: 0.35rem;
    }
    .nav-auth .nav-link {
        border-radius: 0.75rem;
        color: #64748b;
        font-weight: 600;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0.75rem 1rem;
    }
    .nav-auth .nav-link:hover:not(.active) {
        color: #0f172a;
    }
    .nav-auth .nav-link.active {
        background-color: #fff;
        color: #e11d48;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .form-floating-custom {
        position: relative;
        margin-bottom: 1.25rem;
    }
    .form-floating-custom > .form-control {
        border-radius: 1rem;
        border: 2px solid #e2e8f0;
        padding: 1rem 1.25rem;
        height: auto;
        font-size: 1rem;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        color: #0f172a;
    }
    .form-floating-custom > .form-control:focus {
        background-color: #fff;
        border-color: #e11d48;
        box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.1);
    }
    .form-floating-custom > .form-control::placeholder {
        color: transparent;
    }
    .form-floating-custom > label {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        padding: 1rem 1.25rem;
        pointer-events: none;
        border: 2px solid transparent;
        transform-origin: 0 0;
        transition: opacity .1s ease-in-out,transform .1s ease-in-out;
        color: #64748b;
        font-weight: 500;
    }
    .form-floating-custom > .form-control:focus ~ label,
    .form-floating-custom > .form-control:not(:placeholder-shown) ~ label {
        opacity: 0.8;
        transform: scale(0.85) translateY(-2.2rem) translateX(0.5rem);
        background: #fff;
        height: auto;
        padding: 0 0.5rem;
        border-radius: 0.25rem;
        color: #e11d48;
    }

    .btn-auth-submit {
        border-radius: 1rem;
        padding: 0.875rem 1.5rem;
        font-weight: 700;
        font-size: 1.1rem;
        background: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%);
        border: none;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 4px 14px 0 rgba(225, 29, 72, 0.39);
    }
    .btn-auth-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(225, 29, 72, 0.5);
        color: white;
    }

    .social-divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #94a3b8;
        font-size: 0.875rem;
        font-weight: 600;
        margin: 2rem 0;
    }
    .social-divider::before, .social-divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e2e8f0;
    }
    .social-divider:not(:empty)::before { margin-right: 1em; }
    .social-divider:not(:empty)::after { margin-left: 1em; }

    .social-btn {
        border-radius: 1rem;
        padding: 0.875rem;
        font-weight: 600;
        color: #334155;
        background-color: #fff;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
    }
    .social-btn:hover {
        background-color: #f8fafc;
        border-color: #cbd5e1;
        transform: translateY(-2px);
    }
    
    .expert-toggle-card {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1.25rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .expert-toggle-card:hover {
        border-color: #cbd5e1;
    }
    .expert-toggle-card.active {
        background: #fff1f2;
        border-color: #fda4af;
    }

    .file-upload-box {
        border: 2px dashed #cbd5e1;
        border-radius: 1rem;
        padding: 2rem 1rem;
        text-align: center;
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }
    .file-upload-box:hover {
        border-color: #94a3b8;
        background: #f1f5f9;
    }
    .file-upload-box.has-file {
        border-style: solid;
        border-color: #e11d48;
        background: #fff1f2;
    }
    .file-upload-box input[type="file"] {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        opacity: 0; cursor: pointer;
    }

    .auth-illustration {
        background: linear-gradient(135deg, #ff758c 0%, #ff7eb3 100%);
        padding: 3rem;
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        height: 100%;
    }

    /* Horizontal Expansion Transitions */
    .transition-custom {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .modal-dialog {
        transition: max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .expert-fields-horizontal {
        opacity: 0;
        transform: translateX(30px);
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .expert-fields-horizontal.show-horizontal {
        opacity: 1;
        transform: translateX(0);
    }

    .expert-profile-container {
        border-radius: 1.25rem;
        border: 2px solid #e2e8f0;
        background: #fff;
        height: 100%;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
    }

    .expert-profile-header {
        background: linear-gradient(to right, #f8fafc, #f1f5f9);
        padding: 1.5rem;
        border-bottom: 2px solid #e2e8f0;
        border-radius: 1.25rem 1.25rem 0 0;
    }

    .expert-profile-body {
        padding: 2rem 1.5rem;
        flex-grow: 1;
    }

    .profile-field-group {
        position: relative;
        margin-bottom: 2rem;
    }

    .profile-field-group i {
        position: absolute;
        left: 1.25rem;
        top: 1.25rem;
        color: #94a3b8;
        font-size: 1.1rem;
        z-index: 5;
    }

    .profile-field-group .form-control {
        padding-left: 3rem;
    }

    .profile-field-group label {
        left: 3rem;
    }

    .profile-field-group .form-control:focus ~ label,
    .profile-field-group .form-control:not(:placeholder-shown) ~ label {
        transform: scale(0.85) translateY(-2.2rem) translateX(-1.5rem);
    }
</style>

