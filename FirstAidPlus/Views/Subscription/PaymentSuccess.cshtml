@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden position-relative">
                
                <!-- Progress Bar at top of card -->
                <div class="progress rounded-0" style="height: 6px; position: absolute; top:0; left: 0; right: 0;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <div class="card-body p-5 text-center position-relative mt-2">
                    <!-- Background decoration -->
                    <div class="position-absolute top-0 start-0 w-100 h-100 placeholder-glow" style="background: linear-gradient(135deg, rgba(25, 135, 84, 0.05) 0%, rgba(25, 135, 84, 0) 100%); z-index: 0;"></div>
                    
                    <div class="position-relative" style="z-index: 1;">
                        <div class="mb-4 d-inline-flex justify-content-center align-items-center bg-success bg-opacity-10 text-success rounded-circle" style="width: 100px; height: 100px;">
                            <i class="fas fa-check-circle fa-4x" style="animation: bounceIn 0.8s ease-out;"></i>
                        </div>
                        
                        <h2 class="fw-bold text-dark mb-3">Thanh toán hoàn tất!</h2>
                        <h5 class="text-success mb-3 fw-bold">Tài khoản của bạn đã được nâng cấp lên hạng PRO</h5>
                        <p class="text-muted mb-4">Bạn hiện đã có toàn quyền truy cập vào kho thư viện khóa học cao cấp, tính năng Trò chơi gia đình, và thi lấy chứng chỉ quốc tế.</p>
                        
                        @if(TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success fw-medium mb-4 rounded-3 text-start small border-start border-4 border-success">
                                <i class="fas fa-info-circle me-2"></i> @TempData["SuccessMessage"]
                            </div>
                        }
                        
                        <!-- Timeline / Steps visualization -->
                        <div class="d-flex justify-content-between text-muted small px-4 mb-5 position-relative">
                             <div class="position-absolute align-self-center border-top border-2 border-success border-opacity-25" style="left: 15%; right: 15%; top: 30%; z-index: -1;"></div>
                             <div class="text-center">
                                 <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 30px; height: 30px;"><i class="fas fa-check"></i></div>
                                 <span class="fw-bold text-success">Chọn gói</span>
                             </div>
                             <div class="text-center">
                                 <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 30px; height: 30px;"><i class="fas fa-check"></i></div>
                                 <span class="fw-bold text-success">Thanh toán</span>
                             </div>
                             <div class="text-center">
                                 <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 30px; height: 30px; box-shadow: 0 0 0 4px rgba(25,135,84,.2);"><i class="fas fa-check"></i></div>
                                 <span class="fw-bold text-success">Hoàn tất</span>
                             </div>
                        </div>

                        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-4">
                            <a asp-controller="Enrollment" asp-action="MyCourses" class="btn btn-primary px-4 py-3 rounded-pill fw-bold shadow-sm" style="background: linear-gradient(135deg, #0d6efd, #0dcaf0); border: none; transition: transform 0.3s ease;">
                                <i class="fas fa-graduation-cap me-2"></i> Vào phòng học của tôi
                            </a>
                            <a asp-controller="Course" asp-action="Index" class="btn btn-success px-4 py-3 rounded-pill fw-bold shadow-sm" style="background: linear-gradient(135deg, #198754, #20c997); border: none; transition: transform 0.3s ease;">
                                <i class="fas fa-search me-2"></i> Khám phá bài học mới
                            </a>
                        </div>
                        <div class="mt-3">
                             <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small hover-success">
                                Trở về trang chủ
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <p class="text-muted small">
                    Biên lai đã được gửi đến email của bạn. Cần xuất hóa đơn VAT? <a href="#" class="text-decoration-none text-success fw-medium">Bấm vào đây</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes bounceIn {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.2); opacity: 1; }
        100% { transform: scale(1); }
    }
    .btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,.15)!important;
    }
    .hover-success:hover {
        color: #198754 !important;
        text-decoration: underline !important;
    }
</style>
