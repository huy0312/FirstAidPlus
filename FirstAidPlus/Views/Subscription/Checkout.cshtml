@model FirstAidPlus.Models.Plan
@{
    ViewData["Title"] = "Xác nhận thanh toán";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="fw-bold mb-4 text-center">Xác nhận thanh toán</h2>
            
            <div class="card shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-3">Thông tin gói đăng ký</h5>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Gói dịch vụ:</span>
                        <span class="fw-bold fs-5">@Model.Name</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Giá:</span>
                        <span class="fw-bold fs-4 text-danger">@Model.Price.ToString("N0")đ</span>
                    </div>
                    <p class="text-muted small">@Model.Description</p>
                </div>
            </div>

            <form asp-action="Subscribe" method="post">
                <input type="hidden" name="planId" value="@Model.Id" />
                
                <div class="card shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">Chọn phương thức thanh toán</h5>
                        
                        <div class="form-check mb-3 border rounded-3 p-3 d-flex align-items-center border-primary bg-light">
                            <input class="form-check-input mt-0 me-3" type="radio" name="paymentMethod" id="payos" value="PayOS" checked>
                            <label class="form-check-label flex-grow-1 cursor-pointer" for="payos">
                                <div class="fw-bold text-primary">Chuyển khoản QR Tự động (Khuyên dùng)</div>
                                <div class="small text-muted">Thanh toán tự động qua PayOS, cập nhật ngay lập tức.</div>
                            </label>
                            <img src="https://payos.vn/wp-content/uploads/sites/13/2023/07/payos-logo.svg" alt="PayOS" height="30">
                        </div>

                        <div class="form-check mb-3 border rounded-3 p-3 d-flex align-items-center">
                            <input class="form-check-input mt-0 me-3" type="radio" name="paymentMethod" id="vnpay" value="VnPay">
                            <label class="form-check-label flex-grow-1 cursor-pointer" for="vnpay">
                                <div class="fw-bold">Ví VNPAY</div>
                                <div class="small text-muted">Thanh toán qua ví điện tử VNPAY-QR</div>
                            </label>
                            <img src="https://vnpay.vn/assets/images/logo-icon/logo-primary.svg" alt="VNPAY" height="30">
                        </div>

                        <div class="form-check mb-0 border rounded-3 p-3 d-flex align-items-center">
                            <input class="form-check-input mt-0 me-3" type="radio" name="paymentMethod" id="momo" value="Momo">
                            <label class="form-check-label flex-grow-1 cursor-pointer" for="momo">
                                <div class="fw-bold">Ví MoMo</div>
                                <div class="small text-muted">Thanh toán qua ví điện tử MoMo</div>
                            </label>
                            <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" alt="MoMo" height="30">
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">
                        Tiến hành thanh toán
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
