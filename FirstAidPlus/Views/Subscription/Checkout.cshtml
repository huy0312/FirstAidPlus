@model FirstAidPlus.Models.Plan
@{
    ViewData["Title"] = "Xác nhận thanh toán";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="fw-bold mb-4 text-center">Xác nhận thanh toán</h2>
            
            <div class="card shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-3">Thông tin gói đăng ký</h5>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Gói dịch vụ:</span>
                        <span class="fw-bold fs-5">@Model.Name</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Giá:</span>
                        <span class="fw-bold fs-4 text-danger">@Model.Price.ToString("N0")đ</span>
                    </div>
                    <p class="text-muted small">@Model.Description</p>
                </div>
            </div>

            <form asp-action="Subscribe" method="post">
                <input type="hidden" name="planId" value="@Model.Id" />
                
                <div class="card shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">Phương thức thanh toán</h5>
                        
                        <div class="form-check mb-0 border rounded-3 p-4 d-flex align-items-center border-primary bg-light shadow-sm">
                            <input class="form-check-input mt-0 me-3" type="radio" name="paymentMethod" id="payos" value="PayOS" checked required>
                            <label class="form-check-label flex-grow-1 cursor-pointer" for="payos">
                                <div class="fw-bold text-primary fs-5">Chuyển khoản QR Tự động</div>
                                <div class="small text-muted">Thanh toán an toàn qua PayOS. Quét mã QR để hoàn tất ngay lập tức.</div>
                            </label>
                            <img src="https://img.vietqr.io/image/970422-FirstAid-compact.png" alt="PayOS" height="45" class="ms-3">
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">
                        Tiến hành thanh toán
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
