@model IEnumerable<FirstAidPlus.Models.Plan>
@{
    ViewData["Title"] = "Bảng giá";
}

<div class="container text-center py-5">
    <h1 class="fw-bold display-5 mb-3">Chọn gói cá nhân phù hợp nhất</h1>
    <p class="lead text-muted mb-5">Truy cập không giới hạn vào toàn bộ kho khóa học sơ cấp cứu chuẩn quốc tế.</p>
    
    @if(TempData["Message"] != null)
    {
        <div class="alert alert-info d-inline-block px-5">
            @TempData["Message"]
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 justify-content-center g-4 my-4">
        @foreach (var plan in Model)
        {
            if (plan.Price == 159000) continue; // Hide the 159k plan
            var isProfessional = plan.Name.Contains("Professional");
            <div class="col-lg-5 col-md-6 pt-3">
                <div class="card h-100 border rounded-4 shadow-sm @(isProfessional ? "border-danger" : "")" style="@(isProfessional ? "transform: scale(1.05); z-index: 10; overflow: visible;" : "")">
                     @if(isProfessional) {
                        <div class="position-absolute start-50 top-0 translate-middle" style="z-index: 20; width: max-content;">
                            <span class="badge rounded-pill bg-danger px-4 py-2 text-uppercase small fw-bold shadow">Phổ biến nhất</span>
                        </div>
                    }
                    <div class="card-body p-5">
                        <h3 class="fw-bold mb-2">@plan.Name</h3>
                        <p class="text-muted small mb-4">@plan.Description</p>
                        
                        <div class="d-flex justify-content-center align-items-baseline mb-4">
                            <h2 class="display-4 fw-bold text-danger">@plan.Price.ToString("N0")đ</h2>
                            <small class="text-muted fw-bold">/người/tháng</small>
                        </div>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-action="Checkout" asp-route-planId="@plan.Id" class="btn @(isProfessional ? "btn-danger" : "btn-outline-danger") w-100 fw-bold py-3 mb-4 rounded-3">
                                Đăng ký ngay
                            </a>
                        }
                        else
                        {
                            <button type="button" class="btn @(isProfessional ? "btn-danger" : "btn-outline-danger") w-100 fw-bold py-3 mb-4 rounded-3" 
                                    data-bs-toggle="modal" data-bs-target="#loginRegisterModal">
                                Đăng ký ngay
                            </button>
                        }

                        <div class="text-start space-y-3">
                            @if(isProfessional)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Tất cả khóa Starter</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Khóa học nâng cao</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Tùy chỉnh nội dung</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Người quản lý tài khoản</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Hỗ trợ ưu tiên</span>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Tất cả khóa học cơ bản</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Chứng chỉ quốc tế</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Dashboard quản lý</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Hỗ trợ email</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-check text-success fs-5 me-2"></i> <span>Báo cáo tiến độ</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
