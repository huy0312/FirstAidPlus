@model FirstAidPlus.Models.Transaction
@{
    ViewData["Title"] = "Chuyển khoản Ngân hàng";
    var info = $"Thanh toan don hang {Model.Id}";
    var qrUrl = $"https://img.vietqr.io/image/970423-31383886886-compact2.png?amount={Model.Amount}&addInfo={Uri.EscapeDataString(info)}&accountName=HUYNH%20DANG%20TRUONG";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-white text-center border-0 pt-4 pb-0">
                    <img src="https://img.vietqr.io/image/970423-31383886886-compact2.png" alt="TPBank" height="40" class="mb-3" style="object-fit: contain;">
                    <h4 class="fw-bold mb-0">Chuyển khoản / VietQR</h4>
                    <p class="text-muted small">Quét mã dưới đây bằng ứng dụng Ngân hàng</p>
                </div>
                <div class="card-body text-center p-4">
                    <div class="bg-light p-3 rounded-4 mb-4 d-inline-block border">
                        <img src="@qrUrl" alt="Mã QR" class="img-fluid rounded" style="max-width: 300px;">
                    </div>
                    
                    <ul class="list-group list-group-flush text-start mb-4">
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Ngân hàng</span>
                            <span class="fw-bold">TPBank</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Chủ tài khoản</span>
                            <span class="fw-bold">HUYNH DANG TRUONG</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Số tài khoản</span>
                            <span class="fw-bold fs-5 text-primary">31383886886</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Số tiền</span>
                            <span class="fw-bold fs-5 text-danger">@Model.Amount.ToString("N0") VND</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Nội dung</span>
                            <span class="fw-bold fs-6">@info</span>
                        </li>
                    </ul>

                    <form asp-action="BankTransferConfirm" method="post">
                        <input type="hidden" name="transactionId" value="@Model.Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Tôi đã thanh toán</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="alert alert-info border-0 mt-4 d-flex rounded-3 shadow-sm">
                <i class="fas fa-info-circle fs-4 me-3 mt-1 text-primary"></i>
                <div class="small">
                    Vui lòng kiểm tra chính xác <strong>Số tiền</strong> và <strong>Nội dung</strong> trước khi chuyển khoản. (Trong bản thử nghiệm này, bạn có thể nhấn "Tôi đã thanh toán" để kích hoạt gói ngay). Hệ thống tự động kiểm tra trạng thái thanh toán sau mỗi 5 giây.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const transactionId = @Model.Id;
            
            // Poll every 5 seconds
            const intervalId = setInterval(function () {
                $.ajax({
                    url: '/Subscription/CheckPaymentStatus',
                    type: 'GET',
                    data: { transactionId: transactionId },
                    success: function (res) {
                        if (res.success && res.status === 'Success') {
                            clearInterval(intervalId);
                            // Redirect to PaymentSuccess
                            window.location.href = '/Subscription/PaymentSuccess';
                        }
                    },
                    error: function () {
                        console.error('Lỗi khi kiểm tra trạng thái thanh toán.');
                    }
                });
            }, 5000);
        });
    </script>
}
