@model IEnumerable<FirstAidPlus.Models.Course>
@{
    ViewData["Title"] = "Quản lý khóa học";
    Layout = "~/Views/Shared/_ExpertLayout.cshtml";
    var currentSearch = ViewBag.CurrentSearch as string;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var studentCounts = ViewBag.StudentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold mb-0">Quản lý khóa học</h2>
            <p class="text-muted small mb-0">Danh sách các khóa học bạn đã tạo trên hệ thống</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
             <a asp-action="CreateCourse" class="btn btn-primary fw-bold px-4 rounded-3">
                <i class="fas fa-plus me-2"></i> Tạo khóa học mới
            </a>
        </div>
    </div>

    <!-- Filter & Search -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="MyCourses" class="row g-3 align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fas fa-search"></i></span>
                        <input type="text" name="searchString" value="@currentSearch" class="form-control border-start-0 ps-0" placeholder="Tìm tên khóa học..." />
                    </div>
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-dark px-4" type="submit">Lọc</button>
                    @if(!string.IsNullOrEmpty(currentSearch))
                    {
                        <a asp-action="MyCourses" class="btn btn-link text-muted text-decoration-none">Xóa lọc</a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light mt-4">
            <img src="https://cdni.iconscout.com/illustration/premium/thumb/empty-state-2130362-1800926.png" alt="Empty" width="180" class="mb-3 opacity-75" />
            <h4 class="fw-bold text-dark">Chưa có khóa học nào</h4>
            <p class="text-muted">Bắt đầu chia sẻ kiến thức của bạn bằng cách tạo khóa học đầu tiên.</p>
            <a asp-action="CreateCourse" class="btn btn-primary px-4 mt-2">Tạo ngay</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-4 py-3 border-0">Khóa học</th>
                            <th class="py-3 border-0 text-center">Học viên</th>
                            <th class="py-3 border-0 text-center">Trạng thái</th>
                            <th class="py-3 border-0 text-center">Phổ biến</th>
                            <th class="pe-4 py-3 border-0 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            int studentCount = studentCounts.ContainsKey(item.Id) ? studentCounts[item.Id] : 0;
                            <tr>
                                <td class="ps-4 py-3 border-0">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/100x70" : item.ImageUrl)" 
                                             class="rounded-3 me-3" width="70" height="45" style="object-fit: cover;">
                                        <div>
                                            <div class="fw-bold text-dark">@item.Title</div>
                                            <div class="text-muted small">@item.GetFormattedDuration() • @item.Syllabus.Count chương</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 border-0 text-center">
                                    <span class="badge bg-light text-dark rounded-pill px-3">@studentCount</span>
                                </td>
                                <td class="py-3 border-0 text-center">
                                    <form asp-action="ToggleCourseStatus" asp-route-id="@item.Id" method="post" id="toggleForm-@item.Id">
                                        <div class="form-check form-switch d-inline-block">
                                            <input class="form-check-input" type="checkbox" role="switch" id="switch-@item.Id" 
                                                   @(item.IsActive ? "checked" : "") onchange="document.getElementById('toggleForm-@item.Id').submit()">
                                            <label class="form-check-label small ms-1 @(item.IsActive ? "text-success" : "text-danger")" for="switch-@item.Id">
                                                @(item.IsActive ? "Đang bật" : "Đang tắt")
                                            </label>
                                        </div>
                                    </form>
                                </td>
                                <td class="py-3 border-0 text-center">
                                    @if(item.IsPopular)
                                    {
                                        <span class="text-danger" title="Phổ biến"><i class="fas fa-fire"></i></span>
                                    }
                                    else
                                    {
                                        <span class="text-muted opacity-25" title="Bình thường"><i class="fas fa-fire"></i></span>
                                    }
                                </td>
                                <td class="pe-4 py-3 border-0 text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                            <li><a class="dropdown-item py-2" asp-action="EditCourse" asp-route-id="@item.Id"><i class="far fa-edit me-2 text-primary"></i> Chỉnh sửa</a></li>
                                            <li><a class="dropdown-item py-2" asp-controller="Course" asp-action="Details" asp-route-id="@item.Id"><i class="far fa-eye me-2 text-info"></i> Xem trước</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="DeleteCourse" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa khóa học này sẽ ảnh hưởng đến dữ liệu học viên. Bạn có chắc không?')">
                                                    <button type="submit" class="dropdown-item py-2 text-danger"><i class="far fa-trash-alt me-2"></i> Xóa bỏ</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm shadow-sm">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="MyCourses" asp-route-searchString="@currentSearch" asp-route-pageNumber="@(currentPage - 1)">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link @(i == currentPage ? "bg-primary border-primary" : "text-dark")" 
                                   asp-action="MyCourses" asp-route-searchString="@currentSearch" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="MyCourses" asp-route-searchString="@currentSearch" asp-route-pageNumber="@(currentPage + 1)">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Styles {
    <style>
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .backdrop-blur {
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }
    </style>
}
