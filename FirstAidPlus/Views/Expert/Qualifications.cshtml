@model IEnumerable<FirstAidPlus.Models.Qualification>
@{
    ViewData["Title"] = "Chứng chỉ hành nghề";
    Layout = "~/Views/Shared/_ExpertLayout.cshtml";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold mb-0">Hồ sơ năng lực</h2>
            <p class="text-muted small mb-0">Quản lý các chứng chỉ và bằng cấp chuyên môn của bạn</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <button type="button" class="btn btn-primary fw-bold px-4 rounded-3" data-bs-toggle="modal" data-bs-target="#addQualificationModal">
                <i class="fas fa-plus me-2"></i> Thêm chứng chỉ
            </button>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light mt-4">
            <div class="mb-4">
                <i class="fas fa-award text-warning opacity-25" style="font-size: 5rem;"></i>
            </div>
            <h4 class="fw-bold text-dark">Chưa có chứng chỉ nào</h4>
            <p class="text-muted px-md-5">Hãy cập nhật các chứng chỉ hành nghề để tăng độ uy tín cho hồ sơ giảng viên của bạn.</p>
            <button class="btn btn-outline-primary px-4 mt-2" data-bs-toggle="modal" data-bs-target="#addQualificationModal">Cập nhật ngay</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-up">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary">
                                    <i class="fas fa-certificate fa-2x"></i>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-h"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                        <li>
                                            <form asp-action="DeleteQualification" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa chứng chỉ này?')">
                                                <button type="submit" class="dropdown-item text-danger"><i class="far fa-trash-alt me-2"></i> Xóa bỏ</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="mb-3">
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">
                                        <i class="fas fa-clock me-1"></i> Chờ duyệt
                                    </span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">
                                        <i class="fas fa-check-circle me-1"></i> Đã duyệt
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">
                                        <i class="fas fa-times-circle me-1"></i> Từ chối
                                    </span>
                                    @if (!string.IsNullOrEmpty(item.AdminComment))
                                    {
                                        <div class="mt-2 p-2 bg-danger bg-opacity-10 rounded-3 small text-danger">
                                            <i class="fas fa-info-circle me-1"></i> <strong>Lý do:</strong> @item.AdminComment
                                        </div>
                                    }
                                }
                            </div>

                            <h5 class="fw-bold text-dark mb-1">@item.Title</h5>
                            <p class="text-muted small mb-3">Ngày cấp: @item.IssuedAt.ToString("dd/MM/yyyy")</p>
                            
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="text-muted small line-clamp-3 mb-4">@item.Description</p>
                            }

                            @if (!string.IsNullOrEmpty(item.CertificateUrl))
                            {
                                <a href="@item.CertificateUrl" target="_blank" class="btn btn-light w-100 rounded-3 text-primary fw-bold">
                                    <i class="fas fa-external-link-alt me-2"></i> Xem chứng chỉ
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-light w-100 rounded-3 text-muted disabled">
                                    <i class="fas fa-file-image me-2"></i> Không có tệp đính kèm
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Add Qualification Modal -->
<div class="modal fade" id="addQualificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm chứng chỉ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddQualification" method="post" enctype="multipart/form-data">
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên chứng chỉ</label>
                        <input type="text" name="Title" class="form-control rounded-3" placeholder="VD: Chứng chỉ Sơ cấp cứu quốc tế" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mô tả ngắn</label>
                        <textarea name="Description" class="form-control rounded-3" rows="3" placeholder="Thông tin thêm về chứng chỉ..."></textarea>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                             <label class="form-label small fw-bold">Ngày cấp</label>
                             <input type="date" name="IssuedAt" class="form-control rounded-3" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Tệp minh chứng</label>
                            <input type="file" name="certFile" class="form-control rounded-3" accept="image/*,.pdf">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4 rounded-3 fw-bold">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hover-up { transition: transform 0.2s; }
        .hover-up:hover { transform: translateY(-5px); }
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}
