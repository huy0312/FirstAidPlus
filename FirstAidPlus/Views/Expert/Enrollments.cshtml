@model IEnumerable<FirstAidPlus.Models.Enrollment>
@{
    ViewData["Title"] = "Danh sách học viên đăng ký";
    Layout = "~/Views/Shared/_ExpertLayout.cshtml";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">Học viên đã đăng ký khóa học</h5>
        <span class="badge bg-primary rounded-pill">@Model.Count() học viên</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small text-uppercase">
                        <th class="ps-4 border-0">Học viên</th>
                        <th class="border-0">Khóa học</th>
                        <th class="border-0">Ngày đăng ký</th>
                        <th class="border-0">Trạng thái</th>
                        <th class="border-0 text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 border-0">
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(item.User?.FullName ?? "User"))&background=random" class="rounded-circle me-3" width="40" height="40">
                                        <div>
                                            <div class="fw-bold">@item.User?.FullName</div>
                                            <div class="small text-muted">@item.User?.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="border-0">
                                    <span class="fw-medium">@item.Course.Title</span>
                                </td>
                                <td class="border-0">
                                    <div class="small">@item.EnrolledAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">@item.EnrolledAt.ToString("HH:mm")</div>
                                </td>
                                <td class="border-0">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Đang học</span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">@item.Status</span>
                                    }
                                </td>
                                <td class="border-0 text-end pe-4">
                                    <a asp-action="Chat" asp-route-userId="@item.UserId" class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="bi bi-chat-dots me-1"></i> Nhắn tin
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-1 mb-3 d-block opacity-25"></i>
                                Chưa có học viên nào đăng ký các khóa học của bạn.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer bg-white border-0 py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Enrollments" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
