@model IEnumerable<FirstAidPlus.Models.User>
@{
    ViewData["Title"] = "Tin nhắn";
    Layout = "~/Views/Shared/_ExpertLayout.cshtml";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h2 class="fw-bold mb-4">Trò chuyện</h2>
            <div class="list-group shadow-sm">
                @foreach(var user in Model)
                {
                    <a asp-action="Conversation" asp-route-userId="@user.Id" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                        <div class="flex-shrink-0">
                            <img src="@(user.AvatarUrl ?? "https://placehold.co/50x50")" class="rounded-circle" width="50" height="50" alt="@user.FullName">
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h5 class="mb-0 fw-bold">@user.FullName</h5>
                            <small class="text-muted">@user.Email</small>
                        </div>
                        <i class="bi bi-chat-dots fs-4 text-primary"></i>
                    </a>
                }
                @if(!Model.Any())
                {
                    <div class="text-center py-5 text-muted">Chưa có cuộc trò chuyện nào.</div>
                }
            </div>
        </div>
    </div>
</div>
