@model IEnumerable<FirstAidPlus.Models.ViewModels.MyCourseViewModel>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Khóa học của tôi</h2>
    </div>

    <!-- Toolbar: Search & Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="MyCourses" class="row gx-3 gy-2 align-items-center">
                <div class="col-sm-6 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Tìm tên khóa học..." value="@ViewBag.CurrentSearch">
                    </div>
                </div>
                <div class="col-sm-4 col-md-3">
                    <select name="statusFilter" class="form-select">
                        <option value="All" selected="@(ViewBag.CurrentFilter == "All" || string.IsNullOrEmpty(ViewBag.CurrentFilter))">Tất cả trạng thái</option>
                        <option value="Active" selected="@(ViewBag.CurrentFilter == "Active")">Đang học</option>
                        <option value="Completed" selected="@(ViewBag.CurrentFilter == "Completed")">Đã hoàn thành</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary px-4">Lọc</button>
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch) || !string.IsNullOrEmpty(ViewBag.CurrentFilter))
                    {
                        <a asp-action="MyCourses" class="btn btn-outline-secondary ms-2">Xóa lọc</a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info border-0 shadow-sm py-4 text-center">
            <i class="bi bi-journal-x fs-1 text-muted d-block mb-3"></i>
            <h5 class="fw-bold text-dark">Không tìm thấy khóa học</h5>
            <p class="mb-0">Bạn chưa đăng ký khóa học nào hoặc không có kết quả phù hợp với tìm kiếm.</p>
            <a asp-controller="Course" asp-action="Index" class="btn btn-danger mt-3">Khám phá khóa học ngay</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm course-card-hover">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/600x400" : item.ImageUrl)" class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;">
                            @if (item.Status == "Completed")
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-3 px-3 py-2 shadow-sm"><i class="bi bi-check-circle me-1"></i>Đã hoàn thành</span>
                            }
                            else
                            {
                                <span class="badge bg-primary position-absolute top-0 end-0 m-3 px-3 py-2 shadow-sm">Đang học</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-1 line-clamp-2">@item.Title</h5>
                            <p class="card-text text-muted small mb-3">
                                <i class="bi bi-calendar-check me-1"></i>Đăng ký: @item.EnrolledAt.ToString("dd/MM/yyyy")
                            </p>
                            
                            <!-- Progress Bar for Course -->
                            <div class="mb-4 mt-auto">
                                <div class="d-flex justify-content-between align-items-end mb-1">
                                    <small class="text-muted fw-bold">Tiến độ</small>
                                    <small class="fw-bold @(item.Status == "Completed" ? "text-success" : "text-primary")">@item.ProgressPercentage%</small>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar @(item.Status == "Completed" ? "bg-success" : "bg-primary")" role="progressbar" style="width: @item.ProgressPercentage%" aria-valuenow="@item.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted" style="font-size: 0.7rem;">Hoàn thành @item.CompletedLessons / @item.TotalLessons bài học</small>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-outline-danger fw-bold">
                                    @(item.Status == "Completed" ? "Xem lại khóa học" : "Tiếp tục học")
                                </a>
                                @if(item.InstructorId.HasValue)
                                {
                                    <a asp-controller="Chat" asp-action="With" asp-route-partnerId="@item.InstructorId" class="btn btn-light border btn-sm text-dark fw-bold">
                                        <i class="bi bi-chat-dots text-primary me-2"></i>Hỏi đáp chuyên gia
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Course pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="MyCourses" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewBag.CurrentSearch" asp-route-statusFilter="@ViewBag.CurrentFilter">Trước</a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="MyCourses" asp-route-pageNumber="@i" asp-route-searchString="@ViewBag.CurrentSearch" asp-route-statusFilter="@ViewBag.CurrentFilter">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="MyCourses" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewBag.CurrentSearch" asp-route-statusFilter="@ViewBag.CurrentFilter">Tiếp</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .course-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .course-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
</style>
