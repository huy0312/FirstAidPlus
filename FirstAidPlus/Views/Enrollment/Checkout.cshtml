@model FirstAidPlus.Models.Course

@{
    ViewData["Title"] = "Thanh toán khóa học";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 py-3">
                    <h3 class="fw-bold text-danger mb-0"><i class="bi bi-cart4 me-2"></i>Xác nhận thanh toán</h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4 mb-3 mb-md-0">
                             <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/600x400" : Model.ImageUrl)" class="img-fluid rounded shadow-sm" alt="@Model.Title">
                        </div>
                        <div class="col-md-8">
                            <h4 class="fw-bold">@Model.Title</h4>
                            <p class="text-muted small">@Model.Description</p>
                            <div class="d-flex align-items-center gap-3 mt-3">
                                 <span class="badge bg-secondary"><i class="bi bi-clock me-1"></i>@Model.GetFormattedDuration()</span>
                                 <span class="badge bg-success"><i class="bi bi-award me-1"></i>@Model.CertificateName</span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold text-muted">Trạng thái:</span>
                        <span class="fs-4 fw-bold text-success">Đã bao gồm trong gói</span>
                    </div>
                     <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold text-muted">Tổng thanh toán:</span>
                        <span class="fs-3 fw-bold text-danger">0 VNĐ</span>
                    </div>

                    <div class="alert alert-info border-0 d-flex align-items-center gap-3">
                        <i class="bi bi-info-circle-fill fs-4"></i>
                        <div>
                            <strong>Lưu ý:</strong> Đây là bản demo. Khi nhấn "Thanh toán ngay", khóa học sẽ được kích hoạt ngay lập tức vào tài khoản của bạn.
                        </div>
                    </div>

                    <form asp-action="Purchase" method="post">
                        <input type="hidden" name="courseId" value="@Model.Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold py-3">
                                <i class="bi bi-credit-card-2-front me-2"></i>Thanh toán ngay
                            </button>
                            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
