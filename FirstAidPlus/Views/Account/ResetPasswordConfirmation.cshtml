@{
    ViewData["Title"] = "Mật khẩu đã được đặt lại";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center mt-5">
        <div class="card shadow-sm p-5">
            <div class="mb-4">
                <i class="fas fa-check-circle fa-4x text-success"></i>
            </div>
            <h2 class="h4 mb-3">Mật khẩu đã được đặt lại!</h2>
            <p class="text-muted">
                Bạn đã thay đổi mật khẩu thành công. Bây giờ bạn có thể đăng nhập bằng mật khẩu mới của mình.
            </p>
            <a asp-action="Login" class="btn btn-primary mt-3 px-4">Đăng nhập ngay</a>
        </div>
    </div>
</div>
