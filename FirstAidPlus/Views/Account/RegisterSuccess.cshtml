@{
    ViewData["Title"] = "Xác thực tài khoản";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body p-5 text-center">
                    <!-- Icon -->
                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 100px; height: 100px; background: linear-gradient(135deg, @(ViewBag.IsExpert == true ? "#f59e0b 0%, #d97706 100%" : "#667eea 0%, #764ba2 100%"));">
                            @if (ViewBag.IsExpert == true)
                            {
                                <i class="fas fa-user-shield text-white" style="font-size: 3rem;"></i>
                            }
                            else
                            {
                                <i class="fas fa-envelope-open-text text-white" style="font-size: 3rem;"></i>
                            }
                        </div>
                    </div>
                    
                    <h2 class="fw-bold mb-3" style="color: @(ViewBag.IsExpert == true ? "#d97706" : "#667eea");">
                        @(ViewBag.IsExpert == true ? "Đã gửi yêu cầu đăng ký!" : "Kiểm tra Email của bạn!")
                    </h2>
                    
                    @if (ViewBag.IsExpert == true)
                    {
                        <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.7;">
                            Cảm ơn bạn đã đăng ký làm chuyên gia. Hệ thống đã nhận được hồ sơ và các chứng chỉ của bạn.
                            Hồ sơ sẽ được <strong>Admin xét duyệt</strong> trong vòng 24-48 giờ làm việc. 
                        </p>
                        <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                            <i class="fas fa-info-circle me-2"></i>
                            <div class="text-start small">
                                Sau khi duyệt xong, bạn sẽ nhận được email thông báo và có thể bắt đầu tạo khóa học.
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.7;">
                            Chúng tôi đã gửi một email xác thực đến địa chỉ email bạn đã đăng ký. 
                            Vui lòng <strong>mở email</strong> và <strong>nhấp vào link xác thực</strong> để kích hoạt tài khoản.
                        </p>

                        <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <div class="text-start small">
                                Nếu không thấy email, hãy kiểm tra thư mục <strong>Spam</strong> hoặc <strong>Quảng cáo</strong>.
                            </div>
                        </div>
                    }

                    <hr class="my-4"/>

                    @if (ViewBag.IsExpert != true)
                    {
                        <p class="text-muted small mb-3">
                            <i class="fas fa-clock me-1"></i> Link xác thực sẽ hết hạn sau 24 giờ
                        </p>

                        <div class="d-grid gap-2">
                            <a href="https://mail.google.com" target="_blank" class="btn btn-lg fw-bold text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="fas fa-external-link-alt me-2"></i> Mở Gmail
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-home me-2"></i> Về trang chủ
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="d-grid gap-2">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-lg fw-bold text-white" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                                <i class="fas fa-home me-2"></i> Về trang chủ
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
