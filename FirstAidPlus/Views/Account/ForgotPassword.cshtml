@model FirstAidPlus.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu?";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="fas fa-lock fa-3x text-danger mb-3"></i>
                    <h2 class="h4">Quên mật khẩu?</h2>
                    <p class="text-muted small">Nhập email của bạn và chúng tôi sẽ gửi liên kết để đặt lại mật khẩu.</p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Gửi liên kết đặt lại mật khẩu</button>
                </form>
                <div class="mt-3 text-center">
                    <a asp-action="Login" class="text-decoration-none small">Quay lại đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
