@{
    ViewData["Title"] = "Xác thực Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body p-5 text-center">
                    @if (ViewBag.Success != null)
                    {
                        <div class="mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 100px; height: 100px; background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                                <i class="fas fa-check text-white" style="font-size: 3rem;"></i>
                            </div>
                        </div>
                        
                        <h2 class="fw-bold mb-3 text-success">Xác thực thành công!</h2>
                        <p class="text-muted mb-4">@ViewBag.Success</p>
                        
                        <div class="d-grid gap-2">
                            <a href="/" class="btn btn-lg fw-bold text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);" 
                               onclick="showLoginModal()">
                                <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập ngay
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 100px; height: 100px; background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);">
                                <i class="fas fa-times text-white" style="font-size: 3rem;"></i>
                            </div>
                        </div>
                        
                        <h2 class="fw-bold mb-3 text-danger">Xác thực thất bại!</h2>
                        <p class="text-muted mb-4">@(ViewBag.Error ?? "Token không hợp lệ hoặc đã hết hạn.")</p>
                        
                        <div class="d-grid gap-2">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-home me-2"></i> Về trang chủ
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function showLoginModal() {
        window.location.href = '/?showLogin=true';
    }
</script>
