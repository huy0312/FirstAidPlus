@{
    ViewData["Title"] = "Email đã được gửi";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center mt-5">
        <div class="card shadow-sm p-5">
            <div class="mb-4">
                <i class="fas fa-envelope-open-text fa-4x text-success"></i>
            </div>
            <h2 class="h4 mb-3">Kiểm tra email của bạn</h2>
            <p class="text-muted">
                Nếu tài khoản với email đó tồn tại, chúng tôi đã gửi hướng dẫn đặt lại mật khẩu.
            </p>
            <p class="small text-muted">
                Vui lòng kiểm tra hộp thư đến và thư rác.
            </p>
            <a asp-action="Login" class="btn btn-outline-primary mt-3">Quay lại trang đăng nhập</a>
        </div>
    </div>
</div>
