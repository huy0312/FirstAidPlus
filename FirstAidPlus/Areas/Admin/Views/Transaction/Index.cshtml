@model FirstAidPlus.Areas.Admin.ViewModels.TransactionListVM
@using System.Globalization
@{
    ViewData["Title"] = "Lịch sử giao dịch";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-slate-800">Lịch sử giao dịch</h3>
    </div>

    <!-- Filters and Search -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-slate-400">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control border-start-0" placeholder="Tìm theo tên, email, mã GD...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Success" selected="@(Model.StatusFilter == "Success")">Thành công</option>
                        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Chờ xử lý</option>
                        <option value="Failed" selected="@(Model.StatusFilter == "Failed")">Thất bại</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">
                        <i class="bi bi-filter me-1"></i> Lọc
                    </button>
                    <a asp-action="Index" class="btn btn-outline-slate px-4 rounded-pill">
                        Xóa lọc
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-slate-600 extra-small text-uppercase ls-1">
                    <tr>
                        <th class="ps-4 py-3">ID</th>
                        <th class="py-3">Người dùng</th>
                        <th class="py-3">Gói đăng ký</th>
                        <th class="py-3">Số tiền</th>
                        <th class="py-3">Phương thức</th>
                        <th class="py-3">Mã GD</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="pe-4 py-3 text-end">Ngày tạo</th>
                    </tr>
                </thead>
                <tbody class="text-slate-700">
                    @if (Model.Transactions.Any())
                    {
                        @foreach (var tx in Model.Transactions)
                        {
                            <tr>
                                <td class="ps-4 text-slate-400">#@tx.Id</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle-xs me-2" style="background-color: var(--admin-primary); font-size: 0.75rem; color: white;">
                                            @((tx.User?.Username ?? "U").Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-bold small text-dark">@(tx.User?.FullName ?? tx.User?.Username ?? "N/A")</div>
                                            <div class="extra-small text-slate-500">@(tx.User?.Email)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-dark fw-medium">@(tx.Plan?.Name ?? "N/A")</span>
                                </td>

                                <td class="fw-bold">@tx.Amount.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                                <td>
                                    <span class="small">@tx.PaymentMethod</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@tx.Id" class="text-decoration-none hover-indigo">
                                        <span class="extra-small text-indigo-600 font-monospace fw-bold">
                                            @(tx.VnPayTxnRef ?? tx.MomoOrderId ?? tx.Id.ToString("D6"))
                                        </span>
                                    </a>
                                </td>
                                <td>
                                    @if (tx.Status == "Success")
                                    {
                                        <span class="badge bg-success-soft text-success rounded-pill px-3 py-1 extra-small fw-bold">Thành công</span>
                                    }
                                    else if (tx.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-soft text-warning rounded-pill px-3 py-1 extra-small fw-bold">Chờ xử lý</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-soft text-danger rounded-pill px-3 py-1 extra-small fw-bold">Thất bại</span>
                                    }
                                </td>
                                <td class="pe-4 text-end text-slate-500 small">
                                    @tx.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-slate-200 d-block mb-2"></i>
                                <span class="text-slate-400">Không tìm thấy giao dịch nào phù hợp</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top-0 py-3 px-4">
                <nav class="d-flex justify-content-between align-items-center">
                    <div class="small text-slate-500">
                        Hiển thị <b>@Model.Transactions.Count</b> trên <b>@Model.TotalItems</b> giao dịch
                    </div>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-circle border-0" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, status = Model.StatusFilter, page = Model.CurrentPage - 1 })">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link rounded-circle border-0 @(Model.CurrentPage == i ? "shadow-sm" : "")" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, status = Model.StatusFilter, page = i })">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-circle border-0" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, status = Model.StatusFilter, page = Model.CurrentPage + 1 })">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .bg-success-soft { background-color: #ecfdf5; }
    .bg-warning-soft { background-color: #fffbeb; }
    .bg-danger-soft { background-color: #fef2f2; }
    .ls-1 { letter-spacing: 0.05rem; }
    .font-monospace { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .text-indigo-600 { color: #4f46e5; }
    .hover-indigo:hover span { color: #4338ca !important; text-decoration: underline; }
</style>

