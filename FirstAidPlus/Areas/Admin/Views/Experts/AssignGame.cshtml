@model IEnumerable<FirstAidPlus.Models.FamilyCourseCategory>
@{
    ViewBag.Title = "Phân công Trò chơi Gia đình";
    Layout = "_AdminLayout";
    var expert = ViewBag.Expert as FirstAidPlus.Models.User;
    var assignedIds = ViewBag.AssignedIds as List<int> ?? new List<int>();
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold mb-1">Phân công Trò chơi</h2>
            <p class="text-muted mb-0">Chuyên gia: <strong>@expert?.FullName</strong> &mdash; <span class="text-secondary small">@expert?.Email</span></p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Quay lại</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <form asp-action="AssignGame" asp-route-id="@expert?.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="fw-semibold mb-0"><i class="fas fa-gamepad me-2 text-danger"></i>Chọn danh mục trò chơi được phân công</h5>
            </div>
            <div class="card-body">
                @if (!Model.Any())
                {
                    <p class="text-muted text-center py-4">Chưa có danh mục trò chơi nào trong hệ thống.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var cat in Model)
                        {
                            var isChecked = assignedIds.Contains(cat.Id);
                            <div class="col-md-4">
                                <div class="form-check card p-3 border @(isChecked ? "border-danger bg-danger bg-opacity-10" : "border-light") rounded-3 h-100">
                                    <input class="form-check-input" type="checkbox" name="categoryIds" value="@cat.Id" id="cat_@cat.Id" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label d-flex align-items-center gap-2 cursor-pointer w-100" for="cat_@cat.Id">
                                        @if (!string.IsNullOrEmpty(cat.IconUrl))
                                        {
                                            <img src="@cat.IconUrl" class="rounded" width="40" height="40" style="object-fit:cover">
                                        }
                                        else
                                        {
                                            <div class="rounded d-flex align-items-center justify-content-center text-white fw-bold" 
                                                 style="width:40px;height:40px;background-color:@(cat.ColorHex ?? "#e74c3c");font-size:1.2rem;">
                                                @cat.Title.FirstOrDefault()
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold">@cat.Title</div>
                                            @if (!string.IsNullOrEmpty(cat.Description))
                                            {
                                                <div class="text-muted small">@cat.Description</div>
                                            }
                                        </div>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-0 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                <button type="submit" class="btn btn-danger"><i class="fas fa-save me-1"></i> Lưu phân công</button>
            </div>
        </div>
    </form>
</div>
