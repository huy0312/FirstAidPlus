@model FirstAidPlus.Areas.Admin.ViewModels.ExpertListViewModel
@{
    ViewData["Title"] = "Danh sách Chuyên gia";
}

<div class="container-fluid p-0">
    <div class="mb-4">
        <h3 class="fw-bold text-slate-800">Danh sách Chuyên gia</h3>
        <p class="text-slate-500">Xem và quản lý các tài khoản chuyên gia trong hệ thống</p>
    </div>

    <!-- Stats and Search -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 stats-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box-premium bg-indigo-50 text-indigo-600 rounded-3 p-3">
                            <i class="bi bi-people-fill fs-4"></i>
                        </div>
                    </div>
                    <div class="text-slate-500 small fw-bold text-uppercase ls-1 mb-1">Tổng cộng</div>
                    <h2 class="fw-bold mb-0">@Model.Experts.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-9 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden border-start border-primary border-4">
                <div class="card-body p-4 bg-white d-flex align-items-center">
                    <form method="get" class="row g-3 flex-grow-1 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label small text-slate-500 fw-bold text-uppercase ls-1">Tìm kiếm chuyên gia</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-slate-400"><i class="bi bi-search"></i></span>
                                <input type="text" name="search" class="form-control bg-light border-start-0 ps-0 text-slate-700" placeholder="Tên, email chuyên gia..." value="@Model.SearchString" />
                            </div>
                        </div>
                        <div class="col-md-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 fw-bold rounded-3 flex-grow-1">
                                <i class="bi bi-funnel me-1"></i> Lọc
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 fw-bold rounded-3">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Experts Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-custom align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Chuyên gia</th>
                        <th class="py-3">Thông tin liên hệ</th>
                        <th class="py-3">Tiểu sử</th>
                        <th class="py-3">Ngày tạo</th>
                        <th class="py-3 text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model.Experts.Any())
                    {
                        @foreach (var expert in Model.Experts)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle-sm me-3" style="background-color: var(--admin-primary)">
                                            @(expert.FullName != null && expert.FullName.Length > 0 ? expert.FullName.Substring(0, 1).ToUpper() : "E")
                                        </div>
                                        <div>
                                            <div class="fw-bold text-slate-800">@(expert.FullName ?? expert.Username)</div>
                                            <div class="text-slate-500 small">@("@")@expert.Username</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-slate-600"><i class="bi bi-envelope me-2"></i>@expert.Email</div>
                                    @if (!string.IsNullOrEmpty(expert.Phone))
                                    {
                                        <div class="text-slate-500 small"><i class="bi bi-telephone me-2"></i>@expert.Phone</div>
                                    }
                                </td>
                                <td class="text-slate-500">
                                    <div class="text-truncate" style="max-width: 250px;" title="@expert.Bio">
                                        @(expert.Bio ?? "—")
                                    </div>
                                </td>
                                <td class="text-slate-500 fw-medium">
                                    <i class="bi bi-calendar3 me-1 opacity-75"></i>
                                    @expert.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="AssignGame" asp-route-id="@expert.Id" class="btn btn-sm btn-outline-danger shadow-sm rounded-pill px-3 fw-bold">
                                        <i class="fas fa-gamepad me-1"></i> Phân công
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="fas fa-user-md fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">Không tìm thấy chuyên gia nào phù hợp.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Trang <span class="fw-bold text-dark">@Model.CurrentPage</span> / <span class="fw-bold text-dark">@Model.TotalPages</span>
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center" 
                               style="width: 32px; height: 32px;"
                               asp-action="Index" 
                               asp-route-page="@(Model.CurrentPage - 1)" 
                               asp-route-search="@Model.SearchString" 
                               aria-label="Previous">
                                <i class="fas fa-chevron-left small"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center fw-bold @(i == Model.CurrentPage ? "shadow-sm" : "text-muted")" 
                                       style="width: 32px; height: 32px;"
                                       asp-action="Index" 
                                       asp-route-page="@i" 
                                       asp-route-search="@Model.SearchString">@i</a>
                                </li>
                            }
                            else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link border-0 text-muted bg-transparent">...</span>
                                </li>
                            }
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center" 
                               style="width: 32px; height: 32px;"
                               asp-action="Index" 
                               asp-route-page="@(Model.CurrentPage + 1)" 
                               asp-route-search="@Model.SearchString" 
                               aria-label="Next">
                                <i class="fas fa-chevron-right small"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .stats-card {
        transition: all 0.3s ease;
        border-radius: 16px;
    }
    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1) !important;
    }
    .icon-box-premium {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .bg-indigo-50 { background-color: #eef2ff; }
    .text-indigo-600 { color: #4f46e5; }
    
    .table-custom thead th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
        padding-top: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e2e8f0;
    }
    .table-custom tbody td {
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.9rem;
    }
    .avatar-circle-sm {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
    }
    
    .text-slate-800 { color: #1e293b; }
    .text-slate-600 { color: #475569; }
    .text-slate-500 { color: #64748b; }
</style>
