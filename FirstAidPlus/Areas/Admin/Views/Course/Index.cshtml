@model FirstAidPlus.Areas.Admin.ViewModels.CourseManagementVM
@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-bold mb-1 text-slate-800">Thống kê lượt đăng ký</h6>
                <p class="text-slate-500 extra-small mb-0">Top 10 khóa học được đăng ký nhiều nhất</p>
            </div>
            <div class="card-body p-4">
                <div style="height: 300px;">
                    <canvas id="coursePopularityChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-bold mb-1 text-slate-800">Xếp hạng đánh giá</h6>
                <p class="text-slate-500 extra-small mb-0">Điểm trung bình của các khóa học hàng đầu</p>
            </div>
            <div class="card-body p-4">
                <div style="height: 300px;">
                    <canvas id="courseRatingChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center border-bottom">
        <h6 class="m-0 fw-bold text-slate-800">Danh sách tất cả khóa học</h6>
    </div>
    <div class="card-body p-0">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase extra-small fw-bold text-slate-500">ID</th>
                        <th class="py-3 text-uppercase extra-small fw-bold text-slate-500">Hình ảnh</th>
                        <th class="py-3 text-uppercase extra-small fw-bold text-slate-500">Tên khóa học</th>
                        <th class="py-3 text-uppercase extra-small fw-bold text-slate-500">Thời lượng</th>
                        <th class="py-3 text-uppercase extra-small fw-bold text-slate-500">Đánh giá</th>
                        <th class="pe-4 py-3 text-uppercase extra-small fw-bold text-slate-500 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.Courses)
                    {
                        <tr>
                            <td class="ps-4">#@course.Id</td>
                            <td>
                                <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "https://placehold.co/100x100?text=No+Img" : course.ImageUrl)" alt="Course Image" width="48" height="48" class="rounded shadow-sm object-fit-cover">
                            </td>
                            <td>
                                <div class="fw-bold text-link-custom">@course.Title</div>
                            </td>
                            <td>
                                <span class="badge bg-slate-50 text-slate-600 border border-slate-100 rounded-pill">
                                    <i class="bi bi-clock me-1"></i> @course.GetFormattedDuration()
                                </span>
                            </td>
                            <td>
                                @if (course.Feedbacks != null && course.Feedbacks.Any())
                                {
                                    var avg = course.Feedbacks.Average(f => f.Rating);
                                    <div class="d-flex align-items-center">
                                        <span class="text-amber-400 me-2" style="font-size: 0.85rem;">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star@(i <= avg ? "-fill" : (i - 0.5 <= avg ? "-half" : ""))"></i>
                                            }
                                        </span>
                                        <span class="fw-bold text-slate-700">@avg.ToString("0.0")</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-slate-400 small">Chưa có</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khóa học này không?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="bi bi-trash3 me-1"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-slate-800 { color: #1e293b; }
    .text-slate-500 { color: #64748b; }
    .text-slate-400 { color: #94a3b8; }
    .bg-slate-50 { background-color: #f8fafc; }
    .extra-small { font-size: 0.75rem; }
    .text-link-custom { color: #1e293b; transition: color 0.2s; cursor: pointer; }
    .text-link-custom:hover { color: var(--admin-primary); }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Popularity Chart
            const popCtx = document.getElementById('coursePopularityChart').getContext('2d');
            new Chart(popCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.PopularityLabels)),
                    datasets: [{
                        label: 'Số học viên',
                        data: @Html.Raw(Json.Serialize(Model.PopularityData)),
                        backgroundColor: 'rgba(79, 70, 229, 0.1)',
                        borderColor: '#4f46e5',
                        borderWidth: 2,
                        borderRadius: 6,
                        barThickness: 20
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, beginAtZero: true },
                        y: { 
                            grid: { display: false },
                            ticks: { font: { size: 10, weight: '600' } }
                        }
                    }
                }
            });

            // Rating Chart
            const rateCtx = document.getElementById('courseRatingChart').getContext('2d');
            new Chart(rateCtx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.RatingLabels)),
                    datasets: [{
                        label: 'Điểm đánh giá',
                        data: @Html.Raw(Json.Serialize(Model.RatingData)),
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#10b981',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: false },
                        y: { 
                            min: 0, 
                            max: 5,
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });
        });
    </script>
}

