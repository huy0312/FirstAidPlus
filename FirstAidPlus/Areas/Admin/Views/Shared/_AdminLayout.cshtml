@inject FirstAidPlus.Data.AppDbContext _context
@using Microsoft.EntityFrameworkCore
@{
    var pendingQualifications = _context.Qualifications.Include(q => q.User).Where(q => q.Status == "Pending").OrderByDescending(q => q.IssuedAt).Take(5).ToList();
    var pendingQualificationsCount = _context.Qualifications.Count(q => q.Status == "Pending");
    
    var pendingExperts = _context.Users.Where(u => u.RoleId == 3 && !u.IsEmailConfirmed).OrderByDescending(u => u.CreatedAt).Take(5).ToList();
    var pendingExpertsCount = _context.Users.Count(u => u.RoleId == 3 && !u.IsEmailConfirmed);
    
    var totalNotifications = pendingQualificationsCount + pendingExpertsCount;
}
<!DOCTYPE html>


<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --admin-primary: #4f46e5;
            --admin-primary-hover: #4338ca;
            --admin-bg: #f8fafc;
            --sidebar-bg: #0f172a;
            --sidebar-hover: rgba(255, 255, 255, 0.05);
            --sidebar-active: #ffffff;
            --sidebar-text: #94a3b8;
            --card-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --topbar-height: 70px;
        }

        body { 
            background-color: var(--admin-bg); 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            overflow-x: hidden; 
            color: #1e293b;
        }
        
        /* Sidebar Styles */
        .admin-sidebar { 
            width: 260px; 
            min-height: 100vh; 
            background: var(--sidebar-bg);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            position: relative;
        }

        /* Collapsed State */
        .admin-sidebar.collapsed { 
            width: 76px; 
        }

        .admin-sidebar.collapsed .sidebar-text,
        .admin-sidebar.collapsed .sidebar-brand-text {
            display: none !important;
        }
        
        .admin-sidebar.collapsed .sidebar-header {
            justify-content: center;
            padding: 20px 0;
        }
        
        .admin-sidebar.collapsed .sidebar-brand {
            justify-content: center;
        }

        .admin-sidebar.collapsed .nav-link { 
            justify-content: center; 
            padding: 12px 0;
            margin: 8px 12px;
        }

        .admin-sidebar.collapsed .nav-link i { 
            margin-right: 0; 
            font-size: 1.25rem;
        }

        /* Branding */
        .sidebar-header {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: var(--topbar-height);
            margin-bottom: 20px;
        }

        .sidebar-brand {
            color: #fff;
            text-decoration: none !important;
            display: flex;
            align-items: center;
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.5px;
        }
        
        .brand-icon {
            width: 32px;
            height: 32px;
            background: var(--admin-primary);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
        }

        /* Nav Items */
        .admin-sidebar .nav-link { 
            color: var(--sidebar-text); 
            padding: 10px 16px; 
            margin: 4px 16px;
            border-radius: 10px; 
            display: flex;
            align-items: center;
            text-decoration: none !important;
            transition: all 0.3s ease;
            font-weight: 500;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .admin-sidebar .nav-link:hover { 
            background: var(--sidebar-hover); 
            color: #fff; 
        }

        .admin-sidebar .nav-link.active { 
            background: var(--admin-primary); 
            color: #fff; 
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
            font-weight: 600;
        }

        .admin-sidebar .nav-link i { 
            width: 24px; 
            text-align: center; 
            margin-right: 12px;
            font-size: 1.1rem;
            opacity: 0.8;
        }

        /* Toggle Button */
        .toggle-btn {
            background: rgba(255,255,255,0.05);
            border: none;
            color: var(--sidebar-text);
            width: 28px;
            height: 28px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        
        .toggle-btn:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        /* Topbar */
        .admin-topbar {
            height: var(--topbar-height);
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Footer */
        .sidebar-footer {
            padding: 16px;
            margin-top: auto;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
    </style>
</head>
<body>
    <div class="d-flex w-100">
        <!-- Sidebar -->
        <nav class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <span class="ms-2 sidebar-brand-text">FirstAid+ <span class="fw-normal opacity-50 small">Admin</span></span>
                </a>
            </div>

            <ul class="nav flex-column flex-grow-1 py-2">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Dashboard">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span class="sidebar-text">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Users" asp-action="Index"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Quản lý người dùng">
                        <i class="bi bi-people-fill"></i>
                        <span class="sidebar-text">Người dùng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Experts" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Experts" asp-action="Index"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Duyệt chuyên gia">
                        <i class="bi bi-person-check-fill"></i>
                        <span class="sidebar-text">Danh sách chuyên gia</span>
                        @if (pendingExpertsCount > 0)
                        {
                            <span class="badge bg-danger ms-auto rounded-pill" style="font-size: 0.6rem;">@pendingExpertsCount</span>
                        }
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Experts" && ViewContext.RouteData.Values["Action"]?.ToString() == "Qualifications" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Experts" asp-action="Qualifications"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Duyệt chứng chỉ">
                        <i class="bi bi-award-fill"></i>
                        <span class="sidebar-text">Duyệt chứng chỉ</span>
                        @if (pendingQualificationsCount > 0)
                        {
                            <span class="badge bg-danger ms-auto rounded-pill" style="font-size: 0.6rem;">@pendingQualificationsCount</span>
                        }
                    </a>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Course" asp-action="Index"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Quản lý khóa học">
                        <i class="bi bi-journal-bookmark-fill"></i>
                        <span class="sidebar-text">Khóa học</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Transaction" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Transaction" asp-action="Index"
                       data-bs-toggle="tooltip" data-bs-placement="right" title="Lịch sử giao dịch">
                        <i class="bi bi-cash-stack"></i>
                        <span class="sidebar-text">Lịch sử giao dịch</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a class="nav-link text-danger p-2 d-flex align-items-center" 
                   asp-area="" asp-controller="Account" asp-action="Logout"
                   data-bs-toggle="tooltip" data-bs-placement="right" title="Đăng xuất">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="sidebar-text ms-2">Đăng xuất</span>
                </a>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="flex-grow-1 p-0 bg-light" style="min-width: 0; min-height: 100vh;">



            <div class="d-flex flex-column h-100">
                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light admin-topbar static-top px-4">
                    <div class="d-flex justify-content-between w-100 align-items-center">
                        <div class="d-flex align-items-center">
                            <button class="toggle-btn me-3" id="sidebarToggle">
                                <i class="bi bi-list fs-4"></i>
                            </button>
                            <h1 class="h5 mb-0 text-slate-800 fw-bold">@ViewData["Title"]</h1>
                        </div>
                        
                        <div class="d-flex align-items-center gap-2">
                            <!-- Notification Bell Dropdown -->
                            <div class="dropdown">
                                <a class="nav-link position-relative btn btn-light rounded-circle p-0 d-flex align-items-center justify-content-center" 
                                   style="width: 40px; height: 40px;"
                                   href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell text-slate-600 fs-5"></i>
                                    @if(totalNotifications > 0) {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.65rem;">
                                            @totalNotifications
                                            <span class="visually-hidden">thông báo mới</span>
                                        </span>
                                    }
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-0" aria-labelledby="notificationDropdown" style="width: 320px; border-radius: 16px;">
                                    <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light rounded-top-16">
                                        <h6 class="mb-0 fw-bold text-slate-800">Thông báo chờ duyệt</h6>
                                        <span class="badge bg-indigo-100 text-indigo-700 px-2 py-1 extra-small">@totalNotifications mới</span>
                                    </div>
                                    <div class="notification-scroll" style="max-height: 380px; overflow-y: auto;">
                                        @if(pendingExperts.Any()) {
                                            <div class="px-3 py-2 bg-slate-50 border-bottom extra-small fw-bold text-slate-500 text-uppercase">Chuyên gia đang chờ (@pendingExpertsCount)</div>
                                            @foreach(var expert in pendingExperts) {
                                                <a class="dropdown-item d-flex align-items-center p-3 border-bottom hover-bg-light" asp-area="Admin" asp-controller="Experts" asp-action="Index">
                                                    <div class="avatar-circle-xs bg-indigo-100 text-indigo-700 me-3">
                                                        <i class="bi bi-person-badge"></i>
                                                    </div>
                                                    <div class="flex-grow-1 overflow-hidden">
                                                        <div class="small fw-bold text-slate-800 text-truncate">@expert.FullName</div>
                                                        <div class="extra-small text-slate-500">@expert.Email</div>
                                                        <div class="extra-small text-slate-400 mt-1"><i class="bi bi-clock me-1"></i>@expert.CreatedAt.ToString("dd/MM HH:mm")</div>
                                                    </div>
                                                </a>
                                            }
                                        }

                                        @if(pendingQualifications.Any()) {
                                            <div class="px-3 py-2 bg-slate-50 border-bottom extra-small fw-bold text-slate-500 text-uppercase">Chứng chỉ cần duyệt (@pendingQualificationsCount)</div>
                                            @foreach(var qual in pendingQualifications) {
                                                <a class="dropdown-item d-flex align-items-center p-3 border-bottom hover-bg-light" asp-area="Admin" asp-controller="Experts" asp-action="Qualifications">
                                                    @if(!string.IsNullOrEmpty(qual.User?.AvatarUrl)) {
                                                        <img src="@qual.User.AvatarUrl" class="avatar-circle-xs me-3 object-fit-cover" alt="User Avatar">
                                                    } else {
                                                        <div class="avatar-circle-xs bg-emerald-100 text-emerald-700 me-3">
                                                            @((qual.User?.Username ?? "U").Substring(0,1).ToUpper())
                                                        </div>
                                                    }
                                                    <div class="flex-grow-1 overflow-hidden">
                                                        <div class="small fw-bold text-slate-800">@qual.Title</div>
                                                        <div class="extra-small text-slate-500 text-truncate">@qual.User?.FullName</div>
                                                        <div class="extra-small text-slate-400 mt-1"><i class="bi bi-clock me-1"></i>@qual.IssuedAt.ToString("dd/MM HH:mm")</div>
                                                    </div>
                                                </a>
                                            }
                                        }

                                        @if(totalNotifications == 0) {
                                            <div class="p-5 text-center">
                                                <i class="bi bi-check2-circle text-slate-300 fs-1 mb-2 d-block"></i>
                                                <p class="text-slate-500 small mb-0">Tuyệt vời! Không có nội dung chờ duyệt.</p>
                                            </div>
                                        }
                                    </div>
                                    <div class="p-2 border-top text-center bg-light rounded-bottom-16">
                                        <a href="#" class="extra-small fw-bold text-indigo-600 text-decoration-none">Xem tất cả</a>
                                    </div>
                                </div>
                            </div>


                            <div class="vr mx-2 my-2 text-slate-300"></div>

                            <!-- User Information -->
                            <div class="dropdown">
                                <a class="nav-link d-flex align-items-center gap-2 px-2 py-1 rounded-pill hover-bg-light" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <div class="bg-indigo-600 text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:36px;height:36px; background-color: var(--admin-primary)">
                                        <i class="bi bi-person-badge"></i>
                                    </div>
                                    <div class="d-none d-lg-block">
                                        <div class="text-slate-800 small fw-bold lh-1">Admin</div>
                                        <div class="text-slate-500" style="font-size: 0.7rem;">Quản trị viên</div>
                                    </div>
                                    <i class="bi bi-chevron-down small text-slate-400"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 animated--grow-in p-2" style="min-width: 200px; border-radius: 12px;">
                                    <li><a class="dropdown-item rounded-8 py-2 px-3" href="#"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                                    <li><a class="dropdown-item rounded-8 py-2 px-3" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                                    <li><hr class="dropdown-divider mx-3"></li>
                                    <li><a class="dropdown-item text-danger rounded-8 py-2 px-3" asp-area="" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </nav>

                <!-- Page Content -->
                <div class="container-fluid px-4 pb-4">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('adminSidebar');
            const toggleBtn = document.getElementById('sidebarToggle');
            const tooltips = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            
            // Initialize tooltips
            let tooltipList = tooltips.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    trigger: 'hover' // Only specific trigger
                });
            });

            // Toggle Sidebar
            toggleBtn.addEventListener('click', function() {
                sidebar.classList.toggle('collapsed');
                
                // Manage Tooltips: Enable when collapsed, Disable when expanded
                const isCollapsed = sidebar.classList.contains('collapsed');
                
                tooltipList.forEach(t => {
                    if (isCollapsed) {
                        t.enable();
                    } else {
                        t.disable();
                    }
                });
            });

            // Initially disable tooltips if not collapsed (default)
            if (!sidebar.classList.contains('collapsed')) {
                 tooltipList.forEach(t => t.disable());
            }

            // SignalR Connection for Real-time Expert Notifications
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .withAutomaticReconnect()
                .build();

            connection.on("UpdatePendingCount", function (count) {
                const badge = document.querySelector('#notificationDropdown .badge');
                if (count > 0) {
                    if (badge) {
                        badge.childNodes[0].textContent = count;
                        badge.classList.remove('d-none');
                    } else {
                        // Dynamically create badge if it doesn't exist
                        const bell = document.querySelector('#notificationDropdown');
                        const newBadge = document.createElement('span');
                        newBadge.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white';
                        newBadge.style.fontSize = '0.65rem';
                        newBadge.innerHTML = `${count} <span class="visually-hidden">đơn đăng ký mới</span>`;
                        bell.appendChild(newBadge);
                    }
                    
                    // Optional: Highlight bell or play sound
                    const bellIcon = document.querySelector('#notificationDropdown i');
                    bellIcon.classList.add('animate-shake');
                    setTimeout(() => bellIcon.classList.remove('animate-shake'), 1000);
                } else {
                    if (badge) badge.classList.add('d-none');
                }
            });

            connection.start().catch(err => console.error(err.toString()));
        });
    </script>
    <style>
        @@keyframes shake {
            0% { transform: rotate(0); }
            15% { transform: rotate(15deg); }
            30% { transform: rotate(-15deg); }
            45% { transform: rotate(10deg); }
            60% { transform: rotate(-10deg); }
            75% { transform: rotate(5deg); }
            85% { transform: rotate(-5deg); }
            100% { transform: rotate(0); }
        }
        .animate-shake { animation: shake 0.5s ease-in-out; }
    </style>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
