# Environment variables for FirstAidPlus
# Copy these values into a file named .env (NOT pushed to Git)

# Email Settings
EMAIL_MAIL_SERVER=smtp.gmail.com
EMAIL_MAIL_PORT=587
EMAIL_SENDER_NAME=FirstAidPlus
EMAIL_SENDER_EMAIL=your_email@gmail.com
EMAIL_SENDER_PASSWORD=your_email_password_here

# VnPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret

# Momo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# PayOS
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here
